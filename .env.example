# =====================================================================
# Variables d'environnement — copier ce fichier en `.env` puis remplir
# =====================================================================

# ---------- Supabase (auth + base de données) ----------
# Côté serveur
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_PROJECT_ID=your-project-ref
# Clé service-role : UNIQUEMENT côté serveur, ne jamais exposer au client
SUPABASE_SERVICE_ROLE_KEY=

# Côté client (exposées au navigateur — préfixe VITE_ obligatoire)
# Doivent être identiques à leurs équivalents serveur ci-dessus.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ---------- IA (rédaction, OCR, suggestions d'idées) ----------
# OpenRouter — accès aux modèles GPT-5 / Gemini 2.5 utilisés par l'app
OPENROUTER_API_KEY=sk-or-v1-xxx

# ---------- Metricool / webhook n8n (publication réseaux sociaux) ----------
# Optionnel — l'app fonctionne sans, mais la publication automatique est désactivée.
N8N_METRICOOL_WEBHOOK_URL=
